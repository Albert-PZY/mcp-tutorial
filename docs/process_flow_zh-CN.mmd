    classDef transport fill:#FFF3E0,stroke:#FB8C00,color:#E65100,stroke-width:2px;
    classDef llm fill:#F3E5F5,stroke:#8E24AA,color:#4A148C,stroke-width:2px;
    classDef mcp fill:#E0F7FA,stroke:#00ACC1,color:#006064,stroke-width:2px;
    classDef decision fill:#FFEBEE,stroke:#E53935,color:#B71C1C,stroke-width:2px;
    classDef finish fill:#E8EAF6,stroke:#3949AB,color:#1A237E,stroke-width:2px;

    class A start;
    class B config;
    class C,D,E,F transport;
    class G,H,I,J,K,L,Q llm;
