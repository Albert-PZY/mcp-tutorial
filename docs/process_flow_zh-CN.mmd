flowchart TD

    A["[1] 启动客户端<br/>uv run python main.py"]
    B["[2] 读取配置<br/>AppConfig.from_env()"]
    C{"[3] 选择协议<br/>MCP_TRANSPORT"}
    D["[3.1] stdio<br/>PythonStdioTransport(server/stdio.py)"]
    E["[3.2] sse<br/>连接 http://host:port/sse"]
    F["[3.3] streamable_http<br/>连接 http://host:port/mcp"]
    G["[4] 建立 MCP 会话<br/>async with mcp_client"]
    H["[5] 用户输入问题"]
    I["[6] ask_with_llm(...)"]
    J["[7] list_tools()<br/>发现 4 个工具"]
    K["[8] tools schema(4个工具) -> OpenAI tools"]
    L["[9] OpenAI chat.completions.create(...)"]
    M{"[10] 有 tool_calls?"}
    N["[11] 输出最终答案"]
    O["[12] call_tool(selected_name,args)"]
    P["[13] FastMCP 执行选中工具<br/>calculator_add / calculator_subtract / calculator_multiply / calculator_divide"]
    Q["[14] 回填工具结果到 messages"]
    R{"[15] 用户输入 exit?"}
    S["[16] 结束程序"]

    A --> B --> C
    C --> D --> G
    C --> E --> G
    C --> F --> G

    G --> H --> I --> J --> K --> L --> M
    M -- 否 --> N --> R
    M -- 是 --> O --> P --> Q --> L
    R -- 否 --> H
    R -- 是 --> S

